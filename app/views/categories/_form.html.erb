<%= form_with(model: category, class: "card shadow-sm p-4") do |form| %>
  <% if category.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(category.errors.count, "erro") %> impediram salvar a categoria:</h5>
      <ul class="mb-0">
        <% category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Nome da categoria", class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :category_kind_id, "Tipo", class: "form-label" %>
    <%= form.collection_select :category_kind_id, CategoryKind.all, :id, :name,
          { prompt: "Selecione o tipo" },
          { class: "form-select" } %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit "Salvar", class: "btn btn-primary" %>
    <%= link_to "Voltar", categories_path, class: "btn btn-secondary" %>
  </div>
<% end %>