<% content_for :title, "Categorias | Controle Financeiro" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold mb-1">Categorias</h2>
    <p class="text-secondary mb-0">Organize suas receitas e despesas</p>
  </div>

  <%= link_to "Nova categoria", new_category_path, class: "btn btn-primary" %>
</div>

<div class="row g-4">
  <% @categories.each do |category| %>
    <div class="col-md-6 col-lg-4">
      <div class="card p-3 h-100">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h5 class="fw-semibold mb-1"><%= category.name %></h5>
            <p class="text-secondary mb-0">
              <%= category.category_kind&.name || "Sem tipo" %>
            </p>
          </div>

          <% if category.category_kind&.name == "income" %>
            <span class="badge bg-success">Receita</span>
          <% elsif category.category_kind&.name == "expense" %>
            <span class="badge bg-danger">Despesa</span>
          <% else %>
            <span class="badge bg-secondary">Sem tipo</span>
          <% end %>
        </div>

        <div class="d-flex gap-2 mt-auto">
          <%= link_to "Ver", category_path(category), class: "btn btn-outline-primary btn-sm w-100" %>
          <%= link_to "Editar", edit_category_path(category), class: "btn btn-outline-secondary btn-sm w-100" %>
          <%= link_to "Excluir", category_path(category),
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                class: "btn btn-outline-danger btn-sm w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @categories.empty? %>
  <div class="text-center mt-5">
    <p class="text-secondary">Nenhuma categoria cadastrada ainda.</p>
    <%= link_to "Criar primeira categoria", new_category_path, class: "btn btn-primary mt-2" %>
  </div>
<% end %>