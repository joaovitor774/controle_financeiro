<div class="container mt-4">
  <% if notice.present? %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body">
      <h1 class="card-title mb-4"><%= @category.name %></h1>

      <p><strong>Tipo:</strong> <%= @category.category_kind&.name || "Sem tipo" %></p>

      <div class="d-flex gap-2 mt-4">
        <%= link_to "Editar", edit_category_path(@category), class: "btn btn-primary" %>
        <%= link_to "Voltar", categories_path, class: "btn btn-secondary" %>
        <%= link_to "Excluir", category_path(@category),
              data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
              class: "btn btn-danger" %>
      </div>
    </div>
  </div>
</div>