<% content_for :title, "Entrar | Controle Financeiro" %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <div class="mb-3 fs-1">💳</div>
      <h2 class="fw-bold mb-2">Entrar</h2>
      <p class="text-secondary mb-0">Acesse sua conta para continuar</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "seuemail@exemplo.com" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "Digite sua senha" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "Lembrar de mim", class: "form-check-label" %>
        </div>
      <% end %>

      <div class="d-grid mb-3">
        <%= f.submit "Entrar", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>

    <div class="text-center small">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>