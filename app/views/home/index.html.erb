<% content_for :title, "inicio | Controle Financeiro" %>

<div class="p-5 mb-4 bg-white rounded-3 shadow-sm">
  <div class="container-fluid py-3">
    <h1 class="display-6 fw-bold">Bem-vindo ao Controle Financeiro</h1>
    <p class="col-md-8 fs-5 text-secondary">
      Organize suas contas, acompanhe receitas e despesas e gere relatórios mensais com mais clareza.
    </p>

    <hr>

    <div class="row g-3 mt-2">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h5 class="card-title">Contas</h5>
            <p class="card-text text-secondary">Cadastre contas como carteira, banco e poupança.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h5 class="card-title">Lançamentos</h5>
            <p class="card-text text-secondary">Registre entradas e saídas com categoria e data.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h5 class="card-title">Relatórios</h5>
            <p class="card-text text-secondary">Gere relatórios mensais em PDF para análise financeira.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>