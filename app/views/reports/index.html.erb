<% content_for :title, "Relatórios | Controle Financeiro" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold mb-1">Relatórios</h2>
    <p class="text-secondary mb-0">Acompanhe suas movimentações por período</p>
  </div>
</div>

<div class="d-flex justify-content-between mb-3">
  <h4 class="fw-bold">Transações do período</h4>

  <%= link_to "Exportar PDF",
      report_pdf_path(
        start_date: @start_date,
        end_date: @end_date,
        entry_type: params[:entry_type],
        entry_status: params[:entry_status]
      ),
      class: "btn btn-primary" %>
</div>

<div class="card p-4 mb-4">
  <%= form_with url: reports_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
    <div class="col-md-3">
      <%= label_tag :start_date, "Data inicial", class: "form-label" %>
      <%= date_field_tag :start_date, @start_date, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= label_tag :end_date, "Data final", class: "form-label" %>
      <%= date_field_tag :end_date, @end_date, class: "form-control" %>
    </div>

    <div class="col-md-2">
      <%= label_tag :entry_type, "Tipo", class: "form-label" %>
      <%= select_tag :entry_type,
            options_for_select([
              ["Todos", ""],
              ["Entrada", "income"],
              ["Saída", "expense"]
            ], params[:entry_type]),
            class: "form-select" %>
    </div>

    <div class="col-md-2">
      <%= label_tag :entry_status, "Status", class: "form-label" %>
      <%= select_tag :entry_status,
            options_for_select([
              ["Todos", ""],
              ["Pendente", "pending"],
              ["Pago", "paid"],
              ["Cancelado", "canceled"]
            ], params[:entry_status]),
            class: "form-select" %>
    </div>

    <div class="col-md-2">
      <%= submit_tag "Filtrar", class: "btn btn-primary w-100" %>
    </div>
  <% end %>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Entradas no período</p>
      <h3 class="fw-bold text-success mb-0">
        <%= number_to_currency(@income_total, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Saídas no período</p>
      <h3 class="fw-bold text-danger mb-0">
        <%= number_to_currency(@expense_total, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Saldo no período</p>
      <h3 class="fw-bold <%= @balance >= 0 ? 'text-success' : 'text-danger' %> mb-0">
        <%= number_to_currency(@balance, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>
</div>

<div class="card p-4">
  <h4 class="fw-bold mb-3">Transações do período</h4>

  <% if @entries.any? %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Data</th>
            <th>Descrição</th>
            <th>Categoria</th>
            <th>Conta</th>
            <th>Tipo</th>
            <th>Status</th>
            <th class="text-end">Valor</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each do |entry| %>
            <tr>
              <td><%= l(entry.occurred_on) %></td>
              <td><%= entry.description %></td>
              <td><%= entry.category&.name %></td>
              <td><%= entry.account&.name %></td>
              <td>
                <% if entry.entry_type&.name == "income" %>
                  <span class="badge bg-success">Entrada</span>
                <% else %>
                  <span class="badge bg-danger">Saída</span>
                <% end %>
              </td>

              <td>
  <div class="dropdown">
    <% case entry.entry_status&.name %>
    <% when "paid" %>
      <button class="btn btn-primary btn-sm py-0 px-2 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem; border-radius: 0.4rem;">
        Pago
      </button>
    <% when "pending" %>
      <button class="btn btn-warning btn-sm py-0 px-2 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem; border-radius: 0.4rem;">
        Pendente
      </button>
    <% when "canceled" %>
      <button class="btn btn-secondary btn-sm py-0 px-2 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem; border-radius: 0.4rem;">
        Cancelado
      </button>
    <% else %>
      <button class="btn btn-light btn-sm py-0 px-2 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem; border-radius: 0.4rem;">
        -
      </button>
    <% end %>

    <ul class="dropdown-menu">
  <li>
    <%= link_to "Pago",
        update_status_entry_path(entry, status: "paid"),
        data: { turbo_method: :patch },
        class: "dropdown-item" %>
  </li>
  <li>
    <%= link_to "Pendente",
        update_status_entry_path(entry, status: "pending"),
        data: { turbo_method: :patch },
        class: "dropdown-item" %>
  </li>
  <li>
    <%= link_to "Cancelado",
        update_status_entry_path(entry, status: "canceled"),
        data: { turbo_method: :patch },
        class: "dropdown-item text-danger" %>
    </li>
</ul>
  </div>
</td>

              <td class="text-end fw-semibold <%= entry.entry_type&.name == 'income' ? 'text-success' : 'text-danger' %>">
                <%= number_to_currency(entry.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
              </td>
              <td class="text-end fw-semibold <%= entry.entry_type&.name == 'income' ? 'text-success' : 'text-danger' %>">
  <%= number_to_currency(entry.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
</td>

<td class="text-end">
  <div class="dropdown">
    <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown">
      ⋮
    </button>

    <ul class="dropdown-menu dropdown-menu-end">
      <li>
        <%= link_to "Editar",
            edit_entry_path(entry),
            class: "dropdown-item" %>
      </li>

      <li>
        <%= link_to "Excluir",
            entry_path(entry),
            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
            class: "dropdown-item text-danger" %>
      </li>
    </ul>
  </div>
</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-secondary mb-0">Nenhuma transação encontrada no período selecionado.</p>
  <% end %>
</div>