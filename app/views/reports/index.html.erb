<% content_for :title, "Relatórios | Controle Financeiro" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold mb-1">Relatórios</h2>
    <p class="text-secondary mb-0">Acompanhe suas movimentações por período</p>
  </div>
</div>
<div class="d-flex justify-content-between mb-3">
  <h4 class="fw-bold">Transações do período</h4>

  <%= link_to "Exportar PDF",
      report_pdf_path(start_date: @start_date, end_date: @end_date),
      class: "btn btn-primary" %>
</div>
<div class="card p-4 mb-4">
  <%= form_with url: reports_path, method: :get, local: true, class: "row g-3 align-items-end" do |form| %>
    <div class="col-md-4">
      <%= form.label :start_date, "Data inicial", class: "form-label" %>
      <%= form.date_field :start_date, value: @start_date, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= form.label :end_date, "Data final", class: "form-label" %>
      <%= form.date_field :end_date, value: @end_date, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= form.submit "Filtrar", class: "btn btn-primary w-100" %>
    </div>
  <% end %>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Entradas no período</p>
      <h3 class="fw-bold text-success mb-0">
        <%= number_to_currency(@income_total, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Saídas no período</p>
      <h3 class="fw-bold text-danger mb-0">
        <%= number_to_currency(@expense_total, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-4 h-100">
      <p class="text-secondary mb-2">Saldo no período</p>
      <h3 class="fw-bold <%= @balance >= 0 ? 'text-success' : 'text-danger' %> mb-0">
        <%= number_to_currency(@balance, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
    </div>
  </div>
</div>

<div class="card p-4">
  <h4 class="fw-bold mb-3">Transações do período</h4>

  <% if @entries.any? %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Data</th>
            <th>Descrição</th>
            <th>Categoria</th>
            <th>Conta</th>
            <th>Tipo</th>
            <th>Status</th>
            <th class="text-end">Valor</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each do |entry| %>
            <tr>
              <td><%= l(entry.occurred_on) %></td>
              <td><%= entry.description %></td>
              <td><%= entry.category&.name %></td>
              <td><%= entry.account&.name %></td>
              <td>
                <% if entry.entry_type&.name == "income" %>
                  <span class="badge bg-success">Entrada</span>
                <% else %>
                  <span class="badge bg-danger">Saída</span>
                <% end %>
              </td>
              <td>
                <% case entry.entry_status&.name %>
                <% when "paid" %>
                  <span class="badge bg-primary">Pago</span>
                <% when "pending" %>
                  <span class="badge bg-warning text-dark">Pendente</span>
                <% when "canceled" %>
                  <span class="badge bg-secondary">Cancelado</span>
                <% else %>
                  <span class="badge bg-light text-dark">-</span>
                <% end %>
              </td>
              <td class="text-end fw-semibold <%= entry.entry_type&.name == 'income' ? 'text-success' : 'text-danger' %>">
                <%= number_to_currency(entry.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-secondary mb-0">Nenhuma transação encontrada no período selecionado.</p>
  <% end %>
</div>